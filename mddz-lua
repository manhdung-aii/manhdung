-- [[ 6. VÒNG LẶP THỰC THI CHÍNH (MAIN LOOP) ]] --
task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            local LP = game.Players.LocalPlayer
            local Character = LP.Character
            local Root = Character.HumanoidRootPart

            -- PHẦN 1: DRAGON DOJO LOGIC
            if _G.AutoDragonHunter then
                for _, v in pairs(workspace.Enemies:GetChildren()) do
                    if v.Name:find("Dragon Crew") then SmartM1(v, 12) break end
                end
            elseif _G.AutoDragonV2 then
                local Flower = workspace:FindFirstChild("Fire Flower")
                if Flower then Root.CFrame = Flower.CFrame else
                    SmartM1(workspace.Enemies:FindFirstChild("Forest Pirate"), 10)
                end
            elseif _G.AutoDragonV3 then
                local Boss = workspace.Enemies:FindFirstChild("Terror Shark")
                if Boss then SmartM1(Boss, 22) else
                    Root.CFrame = CFrame.new(Root.Position.X + 200, 100, Root.Position.Z + 200)
                end

            -- PHẦN 2: SEA EVENTS (LEVI / KITSUNE / HUNT)
            elseif _G.AutoFindLeviathan or _G.AutoKitsuneIsland or _G.AutoSeaHunter then
                local Seat = Character.Humanoid.SeatPart
                
                -- Ưu tiên đánh quái trước
                local Target = nil
                if _G.AutoSeaHunter then
                    for _, mName in pairs(_G.SelectedSeaMonsters) do
                        local enemy = workspace.Enemies:FindFirstChild(mName)
                        if enemy and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                            Target = enemy; break
                        end
                    end
                end

                if Target then
                    SmartM1(Target, 15)
                elseif Seat and Seat:IsA("VehicleSeat") then
                    local Boat = Seat.Parent
                    if _G.IsDraggingHeart then
                        -- KÉO TIM VỀ TIKI (Bám biển Y=18)
                        Boat:SetPrimaryPartCFrame(CFrame.new(Boat.PrimaryPart.Position, TikiPort))
                        Boat:SetPrimaryPartCFrame(CFrame.new(Boat.PrimaryPart.Position.X, 18, Boat.PrimaryPart.Position.Z) * CFrame.new(0,0,-50))
                    else
                        -- ĐANG TÌM ĐẢO (Lái nhanh)
                        Boat:SetPrimaryPartCFrame(Boat.PrimaryPart.CFrame * CFrame.new(0,0,-75))
                        if _G.AutoFindLeviathan then
                            for _, enemy in pairs(workspace.Enemies:GetChildren()) do
                                if enemy.Name:find("Sea Beast") or enemy.Name:find("Terror Shark") then
                                    Boat:SetPrimaryPartCFrame(Boat.PrimaryPart.CFrame * CFrame.new(0,100,0))
                                end
                            end
                        end
                    end
                end
            end
        end)
    end
end)

