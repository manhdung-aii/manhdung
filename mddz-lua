-- [[ BIẾN TOÀN CỤC - GIỮ NGUYÊN CÁC BIẾN CŨ CỦA SẾP ]] --
_G.AutoFarmLevel = false
_G.AutoFindLeviathan = false
_G.AutoKitsuneIsland = false
_G.AutoSeaHunter = false
_G.IsDraggingHeart = false -- Chế độ kéo tim (Bám biển)
_G.SelectedSeaMonsters = {}
_G.DangerLevelGoal = 6
_G.SelectWeapon = "Melee"

local TikiPort = Vector3.new(-15300, 20, 500)
local SpyNPC = Vector3.new(-15400, 225, 440)

-- [[ 1. HÀNG RÀO ANTI-BAN & NGẮT VẬN TỐC ]] --
local RunService = game:GetService("RunService")
task.spawn(function()
    RunService.Stepped:Connect(function()
        pcall(function()
            if _G.AutoFarmLevel or _G.AutoFindLeviathan or _G.AutoKitsuneIsland or _G.AutoSeaHunter then
                local Root = game.Players.LocalPlayer.Character.HumanoidRootPart
                -- NGẮT VẬN TỐC VẬT LÝ: Server sẽ thấy sếp như đang đứng yên
                Root.Velocity = Vector3.new(0, 0, 0)
                Root.RotVelocity = Vector3.new(0, 0, 0)
            end
        end)
    end)
end)

-- Chống AFK (Treo xuyên đêm)
for _, v in pairs(getconnections(game.Players.LocalPlayer.Idled)) do v:Disable() end

-- [[ 2. HÀM HỖ TRỢ (UTILITIES) ]] --
local function SafeFastAttack()
    local VIM = game:GetService("VirtualInputManager")
    local Delay = math.random(12, 16) / 100 -- Random delay giả lập tay người
    VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    task.wait(Delay)
    VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
end

local function EquipWeapon()
    local p = game.Players.LocalPlayer
    for _, v in pairs(p.Backpack:GetChildren()) do
        if v:IsA("Tool") and (v.ToolTip == _G.SelectWeapon or v.Name:find(_G.SelectWeapon)) then
            p.Character.Humanoid:EquipTool(v)
        end
    end
end

local function SmartM1(Target, Height)
    if Target and Target:FindFirstChild("Humanoid") and Target.Humanoid.Health > 0 then
        EquipWeapon()
        game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = Target.HumanoidRootPart.CFrame * CFrame.new(0, Height or 15, 0)
        SafeFastAttack()
    end
end

-- [[ 3. GIAO DIỆN TABS ]] --
local Tabs = {
    Main = Window:AddTab({ Title = "Main", Icon = "home" }),
    Sea = Window:AddTab({ Title = "Sea Events", Icon = "waves" }),
    Tele = Window:AddTab({ Title = "Teleport", Icon = "map" }) -- Giữ chỗ cho sếp up tiếp
