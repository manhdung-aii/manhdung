-- [[ HỆ THỐNG TỰ THOÁT SAU 30 PHÚT ]] --
task.spawn(function()
    while task.wait(10) do -- Kiểm tra mỗi 10 giây để tiết kiệm tài nguyên
        if _G.AutoLeave30Min then
            local ElapsedTime = tick() - StartTime
            local RemainingTime = 1800 - ElapsedTime -- 30 phút = 1800 giây
            
            -- Thông báo khi còn 1 phút (60 giây)
            if RemainingTime <= 60 and RemainingTime > 50 then
                Fluent:Notify({
                    Title = "NMD HUB TIMER",
                    Content = "Cảnh báo: Sẽ tự động thoát Server sau 60 giây nữa!",
                    Duration = 10
                })
            end
            
            -- Thực hiện thoát khi đủ 30 phút
            if ElapsedTime >= 1800 then
                game.Players.LocalPlayer:Kick("\n[NMD HUB TIMER]\nĐã đủ 30 phút treo máy!\nScript tự động thoát theo cài đặt của bạn.")
            end
        else
            -- Reset lại thời gian nếu người dùng tắt đi rồi bật lại
            StartTime = tick()
        end
    end
end)

