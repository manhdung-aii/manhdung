-- [[ 1. HỆ THỐNG BẢO MẬT ]] --
local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer" and (self.Name == "Admin_Check" or self.Name == "CheatCheck") then return nil end
    return old(self, ...)
end)
setreadonly(mt, true)

