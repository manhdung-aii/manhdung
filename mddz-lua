local function SmartCombat(Target, Height)
    local p = game.Players.LocalPlayer
    local VIM = game:GetService("VirtualInputManager")
    if not Target or not Target:FindFirstChild("Humanoid") or Target.Humanoid.Health <= 0 then return end

    -- TIẾP CẬN
    p.Character.HumanoidRootPart.CFrame = Target.HumanoidRootPart.CFrame * CFrame.new(0, Height or 10, 0)

    -- LOGIC CHIẾN ĐẤU RIÊNG CHO SEA BEAST / THUYỀN MA
    if Target.Name:find("Sea Beast") or Target.Name:find("Ship") or Target.Name:find("Brig") then
        local Wep = p.Backpack:FindFirstChild(_G.SeaEventWeapon) or p.Character:FindFirstChild(_G.SeaEventWeapon)
        if Wep then
            p.Character.Humanoid:EquipTool(Wep)
            for _, key in pairs(_G.SelectedSeaSkills) do
                VIM:SendKeyEvent(true, string.lower(key), false, game); task.wait(0.05)
                VIM:SendKeyEvent(false, string.lower(key), false, game); task.wait(0.2)
            end
            VIM:SendMouseButtonEvent(0,0,0,true,game,0); task.wait(0.1); VIM:SendMouseButtonEvent(0,0,0,false,game,0)
        end
    -- LOGIC CHIẾN ĐẤU CHO QUÁI ĐẤT / BOSS (QUẠT CHẢ M1)
    elseif Target.Name ~= "Leviathan" then
        for _, Wep in pairs(_G.SelectedWeapons) do
            local Tool = p.Backpack:FindFirstChild(Wep) or p.Character:FindFirstChild(Wep)
            if Tool then
                p.Character.Humanoid:EquipTool(Tool)
                -- Fast Attack M1
                VIM:SendMouseButtonEvent(0,0,0,true,game,0); task.wait(0.01); VIM:SendMouseButtonEvent(0,0,0,false,game,0)
                -- Xả Skill bồi thêm
                for _, key in pairs(_G.SelectedSkills) do
                    VIM:SendKeyEvent(true, string.lower(key), false, game); task.wait(0.01); VIM:SendKeyEvent(false, string.lower(key), false, game)
                end
            end
        end
    -- LOGIC CHIẾN ĐẤU RIÊNG CHO LEVIATHAN (KHÔNG M1)
    else
        for _, Wep in pairs(_G.SelectedWeapons) do
            local Tool = p.Backpack:FindFirstChild(Wep) or p.Character:FindFirstChild(Wep)
            if Tool then
                p.Character.Humanoid:EquipTool(Tool)
                for _, key in pairs(_G.SelectedSkills) do
                    VIM:SendKeyEvent(true, string.lower(key), false, game); task.wait(0.1); VIM:SendKeyEvent(false, string.lower(key), false, game); task.wait(0.2)
                end
            end
        end
    end
end

