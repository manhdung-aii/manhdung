-- [[ LOGIC AUTO FARM LEVEL ]] --
task.spawn(function()
    while task.wait() do
        if _G.AutoFarm then
            pcall(function()
                local LP = game.Players.LocalPlayer
                -- Tự động cầm vũ khí
                local Tool = LP.Backpack:FindFirstChild("Melee") or LP.Character:FindFirstChild("Melee")
                if Tool and not LP.Character:FindFirstChild(Tool.Name) then
                    LP.Character.Humanoid:EquipTool(Tool)
                end
                
                -- Tìm quái (Logic đơn giản hóa cho Delta)
                local Enemy = nil
                for _, v in pairs(workspace.Enemies:GetChildren()) do
                    if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                        Enemy = v break
                    end
                end
                
                if Enemy then
                    -- Bay đến quái
                    LP.Character.HumanoidRootPart.CFrame = Enemy.HumanoidRootPart.CFrame * CFrame.new(0, _G.FarmDistance, 0)
                    -- Fast Attack
                    if _G.FastAttack then
                        local Combat = require(LP.PlayerScripts.CombatFramework)
                        local Lib = getupvalue(Combat, 2)
                        if Lib and Lib.activeController then
                            Lib.activeController:attack()
                        end
                    end
                end
            end)
        end
    end
end)

