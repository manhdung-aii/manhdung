Tabs.Sea:AddSection("Săn Quái & Tìm Đảo")

Tabs.Sea:AddMultiDropdown("MonsterSelect", {
    Title = "Chọn Quái Để Đồ Sát",
    Values = {"Sea Beast", "Terror Shark", "Piranha", "Shark", "Electric Wing"},
    Default = {},
    Callback = function(v) _G.SelectedSeaMonsters = v end
})

Tabs.Sea:AddToggle("SeaHunt", { Title = "Bật Chế Độ Săn Quái", Default = false }):OnChanged(function(v) _G.AutoSeaHunter = v end)

Tabs.Sea:AddToggle("Kitsune", { Title = "Auto Tìm Đảo Cáo (Lái Thường)", Default = false }):OnChanged(function(v) _G.AutoKitsuneIsland = v end)

Tabs.Sea:AddToggle("Levi", { Title = "Auto Tìm Leviathan (Bay Cao Bảo Vệ)", Default = false }):OnChanged(function(v) _G.AutoFindLeviathan = v end)

Tabs.Sea:AddToggle("DragHeart", { 
    Title = "CHẾ ĐỘ KÉO TIM (Bám Biển Y=18)", 
    Description = "BẬT KHI ĐÃ MÓC TIM để lôi về Tiki không bị đứt xích.",
    Default = false 
}):OnChanged(function(v) _G.IsDraggingHeart = v end)

-- [[ 4. VÒNG LẶP THỰC THI (MAIN LOOP) ]] --
task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            if _G.AutoFindLeviathan or _G.AutoKitsuneIsland or _G.AutoSeaHunter then
                local LP = game.Players.LocalPlayer
                local Character = LP.Character
                local Root = Character.HumanoidRootPart
                local Seat = Character.Humanoid.SeatPart

                -- KIỂM TRA QUÁI MỤC TIÊU (ƯU TIÊN ĐÁNH TRƯỚC)
                local Target = nil
                if _G.AutoSeaHunter then
                    for _, mName in pairs(_G.SelectedSeaMonsters) do
                        local enemy = workspace.Enemies:FindFirstChild(mName)
                        if enemy and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                            Target = enemy
                            break
                        end
                    end
                end

                if Target then
                    -- Rời ghế để vả quái
                    SmartM1(Target, 15)
                elseif Seat and Seat:IsA("VehicleSeat") then
                    -- LÁI THUYỀN KHI KHÔNG CÓ QUÁI
                    local Boat = Seat.Parent
                    
                    if _G.IsDraggingHeart then
                        -- KÉO TIM: Hướng về Tiki, ép sát mặt nước
                        Boat:SetPrimaryPartCFrame(CFrame.new(Boat.PrimaryPart.Position, TikiPort))
                        Boat:SetPrimaryPartCFrame(CFrame.new(Boat.PrimaryPart.Position.X, 18, Boat.PrimaryPart.Position.Z) * CFrame.new(0,0,-50))
                    else
                        -- ĐI TÌM: Lái nhanh
                        Boat:SetPrimaryPartCFrame(Boat.PrimaryPart.CFrame * CFrame.new(0,0,-70))
                        
                        -- Nếu tìm Levi thì mới bay cao khi gặp quái lạ (không chọn đánh)
                        if _G.AutoFindLeviathan then
                            for _, enemy in pairs(workspace.Enemies:GetChildren()) do
                                if enemy.Name:find("Sea Beast") or enemy.Name:find("Terror Shark") then
                                    Boat:SetPrimaryPartCFrame(Boat.PrimaryPart.CFrame * CFrame.new(0,100,0))
                                end
                            end
                        end
                    end
                end
            end
        end)
    end
end)

