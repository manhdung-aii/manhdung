-- [[ NMD HUB - PHIÊN BẢN ĐẶC BIỆT CHO DELTA ]] --
local success, Fluent = pcall(function()
    return loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
end)

if not success then
    warn("Lỗi load thư viện Fluent, đang thử link dự phòng...")
    Fluent = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/main.lua"))()
end

local Window = Fluent:CreateWindow({
    Title = "NMD HUB",
    SubTitle = "Chơi game vui vẻ nha!",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = false,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl
})

-- [[ HỆ THỐNG LOGO CHỮ D CHO DELTA ]] --
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local Logo = Instance.new("ImageButton", ScreenGui)
Logo.Size = UDim2.new(0, 55, 0, 55)
Logo.Position = UDim2.new(0.1, 0, 0.15, 0)
Logo.Image = "rbxassetid://14457319666" -- ID chữ D xanh
Logo.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
Logo.BackgroundTransparency = 0.4
Logo.Draggable = true
Logo.Active = true
Instance.new("UICorner", Logo).CornerRadius = UDim.new(0, 12)
local Stroke = Instance.new("UIStroke", Logo)
Stroke.Color = Color3.fromRGB(0, 255, 255)
Stroke.Thickness = 2

-- Fix bật/tắt cho Delta Mobile
Logo.MouseButton1Click:Connect(function()
    if Window.Root then
        Window.Root.Visible = not Window.Root.Visible
    end
end)

-- [[ TAB CHỨC NĂNG ]] --
local Tabs = {
    Main = Window:AddTab({ Title = "Auto Farm", Icon = "home" }),
    Settings = Window:AddTab({ Title = "Cài Đặt", Icon = "settings" })
}

-- Nội dung Tab Settings (NMD HUB)
Tabs.Settings:AddSection("Thông Tin Tác Giả")
Tabs.Settings:AddParagraph({
    Title = "NMD HUB",
    Content = "Nhà sản xuất: NMD\nChơi game vui vẻ nha!"
})

_G.AutoFarm = false
_G.FarmDistance = 15

Tabs.Main:AddToggle("Farm", {Title = "Auto Farm Level", Default = false }):OnChanged(function(v) 
    _G.AutoFarm = v 
end)

Tabs.Settings:AddSlider("Distance", {
    Title = "Khoảng cách Farm",
    Default = 15,
    Min = 1,
    Max = 36,
    Rounding = 0,
    Callback = function(v) _G.FarmDistance = v end
})

-- [[ VÒNG LẶP AUTO FARM ]] --
task.spawn(function()
    while task.wait() do
        if _G.AutoFarm then
            pcall(function()
                local Enemy = nil
                for _, v in pairs(workspace.Enemies:GetChildren()) do
                    if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                        Enemy = v break
                    end
                end
                if Enemy then
                    -- Tự cầm vũ khí (Melee)
                    local Tool = game.Players.LocalPlayer.Backpack:FindFirstChild("Melee") or game.Players.LocalPlayer.Character:FindFirstChild("Melee")
                    if Tool and not game.Players.LocalPlayer.Character:FindFirstChild(Tool.Name) then
                        game.Players.LocalPlayer.Character.Humanoid:EquipTool(Tool)
                    end
                    -- Bay đến quái
                    game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = Enemy.HumanoidRootPart.CFrame * CFrame.new(0, _G.FarmDistance, 0)
                end
            end)
        end
    end
end)

Window:SelectTab(1)
Fluent:Notify({Title = "NMD HUB", Content = "Đã tải xong! Chơi game vui vẻ!", Duration = 5})
